APP = zcu216-probe-sfp
APPSOURCES= alpaca_i2c_utils.c zcu216_probe_sfp.c
OUTS = /tftpboot/nfs/rootfs/home/casper/zcu216_probe_sfp
SRCS = alpaca_i2c_utils.c zcu216_probe_sfp.c
INCLUDES =
LIBDIR =
BOARD_FLAG =
OBJS =

%.o: %.c
	$(CC) ${LDFLAGS} ${BOARD_FLAG} $(INCLUDES) ${CFLAGS} -c $(APPSOURCES)

all: $(OBJS)
	$(CC) ${LDFLAGS} $(INCLUDES) $(LIBDIR) $(OBJS) $(SRCS) -o $(OUTS)

clean:
	rm -rf $(OUTS) *.o
