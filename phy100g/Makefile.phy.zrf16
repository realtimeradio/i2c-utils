APP = phy-clk-zrf16
APPSOURCES= alpaca_i2c_utils.c si534x.c
OUTS = /srv/tftpboot/nfs/alpaca/nfs/home/casper/test_si5341
SRCS = ../alpaca_i2c_utils.c si534x.c
INCLUDES = -I../
LIBDIR =
BOARD_FLAG =
OBJS =

%.o: %.c
	$(CC) ${LDFLAGS} ${BOARD_FLAG} $(INCLUDES) ${CFLAGS} -c $(APPSOURCES)

all: $(OBJS)
	$(CC) ${LDFLAGS} $(INCLUDES) $(LIBDIR) $(OBJS) $(SRCS) -o $(OUTS)

clean:
	rm -rf $(OUTS) *.o
